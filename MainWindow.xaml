<Window x:Class="shoppingTechCart.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TechCart - Admin Dashboard" Height="680" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0B0F19">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <Grid>
                <TextBlock Text="ADMIN DASHBOARD - PRODUCT MANAGEMENT" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="System Control Panel" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Main Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Products List -->
            <Border Grid.Column="0" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Products List" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="{StaticResource TextPrimaryBrush}"/>
                    
                    <DataGrid x:Name="dgProducts" 
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              SelectionChanged="dgProducts_SelectionChanged"
                              IsReadOnly="True"
                              VerticalAlignment="Stretch"
                              HorizontalAlignment="Stretch">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ProductId}" Width="60"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="90"/>
                            <DataGridTextColumn Header="Discount" Binding="{Binding Discount}" Width="90"/>
                            <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="70"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type.CategoryName}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Right Panel: Form Editor -->
            <Border Grid.Column="1" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="12,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Product Details" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16" Foreground="{StaticResource TextPrimaryBrush}"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,8,0">
                            <Label Content="Product ID"/>
                            <TextBox Name="txtId" Height="34" VerticalContentAlignment="Center" Margin="0,0,0,8"/>

                            <Label Content="Product Name"/>
                            <TextBox Name="txtName" Height="34" VerticalContentAlignment="Center" Margin="0,0,0,8"/>

                            <Label Content="Price"/>
                            <TextBox Name="txtPrice" Height="34" VerticalContentAlignment="Center" Margin="0,0,0,8"/>

                            <Label Content="Discount"/>
                            <TextBox Name="txtDiscount" Height="34" VerticalContentAlignment="Center" Margin="0,0,0,8"/>

                            <Label Content="Unit"/>
                            <TextBox Name="txtUnit" Height="34" VerticalContentAlignment="Center" Margin="0,0,0,8"/>

                            <Label Content="Category Type"/>
                            <ComboBox Name="cbxType" Height="34" VerticalContentAlignment="Center" Margin="0,0,0,16"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Control Buttons -->
                    <UniformGrid Grid.Row="2" Columns="3" Rows="1" Height="38" Margin="0,16,0,0">
                        <Button Name="btnAdd" Content="ADD" Margin="0,0,4,0" Style="{StaticResource AccentGradientButton}" Click="btnAdd_Click"/>
                        <Button Name="btnUpdate" Content="UPDATE" Margin="4,0,4,0" Style="{StaticResource {x:Type Button}}" Click="btnUpdate_Click"/>
                        <Button Name="btnDelete" Content="DELETE" Margin="4,0,0,0" Style="{StaticResource SecondaryButton}" Click="btnDelete_Click"/>
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
