<Window x:Class="shoppingTechCart.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:shoppingTechCart.Services"
        Title="TechCart - Secure Shopping" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#0B0F19">
    <Window.Resources>
        <services:ImagePathConverter x:Key="ImagePathConverter" />

        <!-- Custom TabItem Style -->
        <Style x:Key="ModernTabItem" TargetType="TabItem">
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="14" FontWeight="Bold" Margin="4,2"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border"
                                Background="Transparent"
                                BorderThickness="0,0,0,3"
                                BorderBrush="Transparent"
                                Padding="20,12"
                                Margin="0,0,8,0"
                                Cursor="Hand">
                            <ContentPresenter x:Name="contentPresenter"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="false">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HiddenTabItem" TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Width="0" Height="0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom ListBoxItem Style for Product Cards -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="border"
                                Background="Transparent"
                                BorderThickness="2"
                                BorderBrush="Transparent"
                                CornerRadius="10"
                                Padding="0">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#10FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <Grid>
                <TextBlock Text="TECHCART ELECTRONIC SHOPPING PORTAL" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                
                <!-- Toggleable Shopping Cart Button / Icon on Right Header -->
                <Button x:Name="btnToggleCart" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Center"
                        Margin="0,0,120,0"
                        Padding="12,6"
                        Style="{StaticResource SecondaryButton}"
                        Click="btnToggleCart_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🛒 View Cart" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
                <Button x:Name="btnOpenProfile"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Padding="12,6"
                        Style="{StaticResource SecondaryButton}"
                        Click="btnOpenProfile_Click">
                    <TextBlock Text="My Profile" FontWeight="Bold"/>
                </Button>
            </Grid>
        </Border>

        <!-- Main Body TabControl -->
        <TabControl x:Name="mainTabControl" Grid.Row="1" Background="Transparent" BorderThickness="0">
            <!-- Tab 1: Shopping Center -->
            <TabItem Header="SHOPPING CENTER" Style="{StaticResource ModernTabItem}">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Column 0: Product Grid list -->
                    <Border Grid.Column="0" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,12,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Products Catalog" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="{StaticResource TextPrimaryBrush}"/>

                            <ListBox x:Name="lbProducts"
                                     Grid.Row="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Margin="0,0,-12,0"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource BgBrush}"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Width="220"
                                                Height="220"
                                                Padding="0">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="100"/> <!-- Image area -->
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <!-- Product Image -->
                                                <Border Grid.Row="0" CornerRadius="8,8,0,0" ClipToBounds="True" Background="#131824">
                                                    <Image Source="{Binding ProductImage, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill"/>
                                                </Border>

                                                <Grid Grid.Row="1" Margin="12">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Category Name -->
                                                    <TextBlock Grid.Row="0" Text="{Binding Type.CategoryName}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>

                                                    <!-- Product Title -->
                                                    <TextBlock Grid.Row="1" 
                                                               Text="{Binding ProductName}" 
                                                               FontSize="13" 
                                                               FontWeight="SemiBold" 
                                                               TextWrapping="Wrap" 
                                                               Margin="0,4,0,0"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               VerticalAlignment="Top"/>

                                                    <!-- Price & Discount -->
                                                    <Grid Grid.Row="2">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Price, StringFormat={}{0:N0} VND}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                            <TextBlock Text="{Binding Discount, StringFormat={}Discount: {0:N0} VND}" FontSize="10" Foreground="#FF4A4A" FontWeight="SemiBold" Visibility="{Binding Discount, Converter={x:Null}}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- Column 1: Detailed Product Info Panel -->
                    <Border Grid.Column="1" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="12,0,12,0">
                        <Grid DataContext="{Binding SelectedItem, ElementName=lbProducts}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="140"/> <!-- Large Image -->
                                <RowDefinition Height="*"/> <!-- Info and brief -->
                                <RowDefinition Height="Auto"/> <!-- Add button -->
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Product Details" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="{StaticResource TextPrimaryBrush}"/>

                            <!-- Large product image -->
                            <Border Grid.Row="1" CornerRadius="8" ClipToBounds="True" Background="{StaticResource BgBrush}" Margin="0,0,0,12">
                                <Image Source="{Binding ProductImage, Converter={StaticResource ImagePathConverter}}" Stretch="Uniform"/>
                            </Border>

                            <!-- Product information -->
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="{Binding ProductName}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                    
                                    <Grid Margin="0,4,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Label Grid.Row="0" Grid.Column="0" Content="Product ID:" Padding="0,2,8,2"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ProductId}" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>

                                        <Label Grid.Row="1" Grid.Column="0" Content="Category:" Padding="0,2,8,2"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Type.CategoryName}" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>

                                        <Label Grid.Row="2" Grid.Column="0" Content="Unit:" Padding="0,2,8,2"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Unit}" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>

                                        <Label Grid.Row="3" Grid.Column="0" Content="Price:" Padding="0,2,8,2"/>
                                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Price, StringFormat={}{0:N0} VND}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Discount, StringFormat={} (Disc: -{0:N0} VND)}" Foreground="#FF4A4A" FontSize="11" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>

                                    <Border BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}" Margin="0,4,0,8"/>

                                    <TextBlock Text="FUNCTIONAL DESCRIPTION" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <!-- Brief / Origin Info -->
                                    <TextBlock Text="{Binding Brief}" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" LineHeight="18"/>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Add to Cart button inside details panel -->
                            <Button Grid.Row="3" 
                                    Content="ADD TO SHOPPING CART"
                                    Height="38"
                                    Margin="0,12,0,0"
                                    Style="{StaticResource AccentGradientButton}"
                                    Click="btnAddToCart_Click"/>
                        </Grid>
                    </Border>

                    <!-- Column 2: Toggleable Cart Panel -->
                    <Border x:Name="cartBorder" Grid.Column="2" Width="300" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="12,0,0,0" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Your Shopping Cart" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="{StaticResource TextPrimaryBrush}"/>

                            <DataGrid x:Name="dgCart"
                                      Grid.Row="1"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      VerticalAlignment="Stretch"
                                      HorizontalAlignment="Stretch">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Product" Binding="{Binding Product.ProductName}" Width="*"/>
                                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="50"/>
                                    <DataGridTextColumn Header="Price" Binding="{Binding Product.Price, StringFormat={}{0:N0}}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Cart Actions -->
                            <StackPanel Grid.Row="2" Margin="0,12,0,0">
                                <Button Content="Remove Selected Item"
                                        Height="34"
                                        Margin="0,0,0,8"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="btnRemoveFromCart_Click"/>

                                <Button Content="Create Order"
                                        Height="36"
                                        Margin="0,0,0,8"
                                        Style="{StaticResource AccentGradientButton}"
                                        Click="btnCreateOrder_Click"/>

                                <Button Content="Pay Cash (Complete Purchase)"
                                        Height="36"
                                        Style="{StaticResource {x:Type Button}}"
                                        Click="btnPayCash_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 2: User Profile Management -->
            <TabItem Header="MY PROFILE" Style="{StaticResource HiddenTabItem}">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="500"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="1" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="28" VerticalAlignment="Top" Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="ACCOUNT PROFILE MANAGEMENT" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="Update your personal details and credentials" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,24"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <Label Content="First Name"/>
                                    <TextBox x:Name="txtFirstName" Height="34" VerticalContentAlignment="Center" Margin="0,0,0,8"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <Label Content="Last Name"/>
                                    <TextBox x:Name="txtLastName" Height="34" VerticalContentAlignment="Center" Margin="0,0,0,8"/>
                                </StackPanel>
                            </Grid>

                            <Label Content="Phone Number"/>
                            <TextBox x:Name="txtPhone" Height="34" VerticalContentAlignment="Center" Margin="0,0,0,8"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <Label Content="Birthday"/>
                                    <DatePicker x:Name="dpBirthday" Height="34" VerticalContentAlignment="Center" Margin="0,0,0,8"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <Label Content="Gender"/>
                                    <ComboBox x:Name="cbxGender" Height="34" VerticalContentAlignment="Center" Margin="0,0,0,8">
                                        <ComboBoxItem Content="Male"/>
                                        <ComboBoxItem Content="Female"/>
                                        <ComboBoxItem Content="Other"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <Border BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}" Margin="0,12,0,16"/>

                            <Label Content="New Password (leave blank to keep current)"/>
                            <PasswordBox x:Name="txtNewPassword" Height="34" VerticalContentAlignment="Center" Margin="0,0,0,24"/>

                            <Button Content="SAVE PROFILE CHANGES"
                                    Height="38"
                                    Style="{StaticResource AccentGradientButton}"
                                    Click="btnSaveProfile_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
