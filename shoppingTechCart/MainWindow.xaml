<Window x:Class="shoppingTechCart.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:shoppingTechCart"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800">
    <StackPanel>
        <DataGrid x:Name="dgProducts" 
                  Height="180"
                  Width="800" 
                  Margin="10"
                  AutoGenerateColumns="False"
                  SelectionChanged="dgProducts_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ProductId}" Width="80"/>
                <DataGridTextColumn Header="Name" Binding="{Binding ProductName}" Width="200"/>
                <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="100"/>
                <DataGridTextColumn Header="Discount" Binding="{Binding Discount}" Width="100"/>
                <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="80"/>
                <DataGridTextColumn Header="Type" Binding="{Binding Type.CategoryName}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <Label Content="Id"/>
        <TextBox Name="txtId"/>
        
        <Label Content="Name"/>
        <TextBox Name="txtName"/>
        
        <Label Content="Price"/>
        <TextBox Name="txtPrice"/>
        
        <Label Content="Discount"/>
        <TextBox Name="txtDiscount"/>
        
        <Label Content="Unit"/>
        <TextBox Name="txtUnit"/>
        
        <Label Content="Type"/>
        <ComboBox Name="cbxType"/>

        <Button Name="btnAdd" Content="Add" Click="btnAdd_Click" />
        <Button Name="btnUpdate" Content="Update" Click="btnUpdate_Click" />
        <Button Name="btnDelete" Content="Delete" Click="btnDelete_Click" />


    </StackPanel>
</Window>
