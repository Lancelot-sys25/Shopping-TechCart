<Window x:Class="shoppingTechCart.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shopping" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <Label Content="Products"/>
            <DataGrid x:Name="dgProducts"
                      Height="400"
                      AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ProductId}" Width="80"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding ProductName}" Width="200"/>
                    <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="100"/>
                    <DataGridTextColumn Header="Discount" Binding="{Binding Discount}" Width="100"/>
                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="80"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding Type.CategoryName}" Width="140"/>
                </DataGrid.Columns>
            </DataGrid>

            <Button Content="Add to Cart"
                    Height="32"
                    Margin="0,8,0,0"
                    Click="btnAddToCart_Click"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="10,0,0,0">
            <Label Content="Cart"/>
            <DataGrid x:Name="dgCart"
                      Height="400"
                      AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Product" Binding="{Binding Product.ProductName}" Width="150"/>
                    <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="80"/>
                    <DataGridTextColumn Header="Price" Binding="{Binding Product.Price}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>

            <Button Content="Remove from Cart"
                    Height="32"
                    Margin="0,8,0,0"
                    Click="btnRemoveFromCart_Click"/>

            <Button Content="Create Order"
                    Height="32"
                    Margin="0,8,0,0"
                    Click="btnCreateOrder_Click"/>

            <Button Content="Pay Cash"
                    Height="32"
                    Margin="0,8,0,0"
                    Click="btnPayCash_Click"/>
        </StackPanel>
    </Grid>
</Window>
